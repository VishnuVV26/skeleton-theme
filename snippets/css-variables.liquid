{% style %}
  {% # Heading font face variants %}
  {{ settings.type_heading_font | font_face: font_display: 'swap' }}
  {{ settings.type_heading_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ settings.type_heading_font | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}

  {% # Body font face variants %}
  {{ settings.type_body_font | font_face: font_display: 'swap' }}
  {{ settings.type_body_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ settings.type_body_font | font_modify: 'weight', 'bold' | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}
  {{ settings.type_body_font | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}

  :root {
    --font-heading--family: {{ settings.type_heading_font.family }}, {{ settings.type_heading_font.fallback_families }};
    --font-heading--weight: {{ settings.type_heading_font.weight }};
    --font-heading--style: {{ settings.type_heading_font.style }};

    --font-body--family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    --font-body--weight: {{ settings.type_body_font.weight }};
    --font-body--style: {{ settings.type_body_font.style }};

    --heading-text-transform: {{ settings.heading_text_transform }};
    --heading-font-weight: {{ settings.heading_weight }};
    --heading-line-height: {{ settings.heading_line_height | divided_by: 100.0 }};
    --heading-letter-spacing: {{ settings.heading_letter_spacing }}px;

    --h1-font-size: {{ settings.h1_font_size }}px;
    --h2-font-size: {{ settings.h2_font_size }}px;
    --h3-font-size: {{ settings.h3_font_size }}px;
    --h4-font-size: {{ settings.h4_font_size }}px;
    --h5-font-size: {{ settings.h5_font_size }}px;
    --h6-font-size: {{ settings.h6_font_size }}px;

    --body-font-size: {{ settings.body_font_size }}px;
    --body-line-height: {{ settings.body_line_height | divided_by: 100.0 }};
    --body-letter-spacing: {{ settings.body_letter_spacing }}px;

    --page-width: {{ settings.max_page_width }};
    --page-margin: {{ settings.min_page_margin }}px;

    --logo-width: {{ settings.logo_width }}px;

    --color-background: {{ settings.background_color }};
    --color-foreground: {{ settings.foreground_color }};
    --color-heading: {{ settings.color_heading }};
    --color-success: {{ settings.color_success }};
    --color-error: {{ settings.color_error }};

    --color-header-bg: {{ settings.color_header_bg }};
    --color-header-text: {{ settings.color_header_text }};

    --color-footer-bg: {{ settings.color_footer_bg }};
    --color-footer-text: {{ settings.color_footer_text }};

    --color-btn-primary-bg: {{ settings.color_btn_primary_bg }};
    --color-btn-primary-text: {{ settings.color_btn_primary_text }};
    --color-btn-secondary-bg: {{ settings.color_btn_secondary_bg }};
    --color-btn-secondary-text: {{ settings.color_btn_secondary_text }};

    --color-star-rating: {{ settings.color_star_rating }};
    --color-on-sale: {{ settings.color_on_sale }};
    --color-sold-out: {{ settings.color_sold_out }};
    --color-custom-label: {{ settings.color_custom_label }};
    --color-custom-label-2: {{ settings.color_custom_label_2 }};
    --color-in-stock: {{ settings.color_in_stock }};
    --color-low-stock: {{ settings.color_low_stock }};

    --style-border-radius-inputs: {{ settings.input_corner_radius }}px;
  }
{% endstyle %}
