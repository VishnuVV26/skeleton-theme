<script type="application/ld+json">
{

  "@context": "https://schema.org",

  "@type": "CollectionPage",

  "name": {{ collection.title | json }},

  "url": {{ shop.url | append: collection.url | json }},

  "description": {{ collection.description | strip_html | truncatewords: 100 | json }}

  {%- if collection.image -%}

  ,"image": {{ collection.image | image_url: width: 800 | prepend: 'https:' | json }}

  {%- endif -%}

  ,"hasPart": [

    {%- for product in collection.products limit: 10 -%}

    {

      "@type": "Product",

      "name": {{ product.title | json }},

      "url": {{ shop.url | append: product.url | json }}

      {%- if product.featured_image -%}

      ,"image": {{ product.featured_image | image_url: width: 400 | prepend: 'https:' | json }}

      {%- endif -%}

      ,"offers": {

        "@type": "Offer",

        "price": "{{ product.price | money_without_currency | strip_html }}",

        "priceCurrency": {{ cart.currency.iso_code | json }},

        "availability": {% if product.available %}"https://schema.org/InStock"{% else %}"https://schema.org/OutOfStock"{% endif %}

      }

    }{% unless forloop.last %},{% endunless %}

    {%- endfor -%}

  ]

}
</script>
