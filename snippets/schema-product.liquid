<script type="application/ld+json">

{

  "@context": "https://schema.org",

  "@type": "Product",

  "name": {{ product.title | json }},

  "url": {{ shop.url | append: product.url | json }},

  "description": {{ product.description | strip_html | truncatewords: 100 | json }},

  "brand": {

    "@type": "Brand",

    "name": {{ product.vendor | json }}

  }

  {%- if product.featured_image -%}

  ,"image": [

    {{ product.featured_image | image_url: width: 800 | prepend: 'https:' | json }}

  ]

  {%- endif -%}

  ,"offers": [

    {%- for variant in product.variants -%}

    {

      "@type": "Offer",

      "name": {{ variant.title | json }},

      "sku": {{ variant.sku | json }},

      "price": "{{ variant.price | money_without_currency | strip_html }}",

      "priceCurrency": {{ cart.currency.iso_code | json }},

      "availability": {% if variant.available %}"https://schema.org/InStock"{% else %}"https://schema.org/OutOfStock"{% endif %},

      "url": {{ shop.url | append: product.url | append: '?variant=' | append: variant.id | json }}

    }{% unless forloop.last %},{% endunless %}

    {%- endfor -%}

  ]

}

</script>
